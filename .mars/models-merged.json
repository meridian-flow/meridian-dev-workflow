{
  "opus": {
    "provider": "anthropic",
    "match": [
      "*opus*"
    ]
  },
  "sonnet": {
    "provider": "anthropic",
    "match": [
      "*sonnet*"
    ]
  },
  "haiku": {
    "provider": "anthropic",
    "match": [
      "*haiku*"
    ]
  },
  "codex": {
    "provider": "openai",
    "match": [
      "*codex*"
    ],
    "exclude": [
      "*-mini",
      "*-spark",
      "*-max"
    ]
  },
  "gpt": {
    "provider": "openai",
    "match": [
      "gpt-5*"
    ],
    "exclude": [
      "*codex*",
      "*-mini",
      "*-nano",
      "*-chat",
      "*-turbo"
    ]
  },
  "gemini": {
    "provider": "google",
    "match": [
      "gemini*",
      "*pro*"
    ],
    "exclude": [
      "*-customtools"
    ]
  }
}